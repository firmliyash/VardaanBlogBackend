# Port the Express/Apollo server listens on
PORT=4000

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/blogApp
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/blogApp
MONGO_URI=mongodb://127.0.0.1:27017/blogApp

# Comma separated list of origins allowed to call the API (frontend URLs)
CLIENT_ORIGIN=http://localhost:5173
